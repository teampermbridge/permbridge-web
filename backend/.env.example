# PermBridge Backend Environment Variables
# Copy this to .env and fill in your actual values

# PostgreSQL Database
DATABASE_URL=postgresql://permbridge_user:permbridge_password@localhost:5432/permbridge

# Salesforce OAuth (Required for Connect to Salesforce feature)
# NOTE: Use External Client App (not Connected App—deprecated as of Spring '26)
# 1. Create External Client App in Salesforce Setup > App Manager > New External Client App
# 2. Enable OAuth, select Web Server Flow, add scopes: api, refresh_token, web, openid
# 3. Set Callback URL to: http://localhost:3001/api/auth/salesforce/callback
# 4. Get Consumer Key and Consumer Secret from app details
# See SETUP.md section 3 for detailed instructions
SALESFORCE_CLIENT_ID=your-consumer-key-here
SALESFORCE_CLIENT_SECRET=your-consumer-secret-here
SALESFORCE_REDIRECT_URI=http://localhost:3001/api/auth/salesforce/callback
SALESFORCE_INSTANCE_URL=https://login.salesforce.com

# App Configuration
PORT=3001
NODE_ENV=development

# JWT Authentication
# IMPORTANT: Change this to a secure random string for production
JWT_SECRET=permbridge-dev-secret-change-in-production

# Claude AI API (for permission analysis features)
ANTHROPIC_API_KEY=your-api-key-here
