# PermBridge Backend Environment Variables
# Copy this to .env and fill in your actual values

# PostgreSQL Database
DATABASE_URL=postgresql://permbridge_user:permbridge_password@localhost:5432/permbridge

# Salesforce OAuth (Required for Connect to Salesforce feature)
# 1. Create Connected App in Salesforce Setup > Apps > App Manager
# 2. Copy Consumer Key and Consumer Secret
# 3. Set Callback URL in app to: http://localhost:3001/api/auth/salesforce/callback
SALESFORCE_CLIENT_ID=your-consumer-key-here
SALESFORCE_CLIENT_SECRET=your-consumer-secret-here
SALESFORCE_REDIRECT_URI=http://localhost:3001/api/auth/salesforce/callback
SALESFORCE_INSTANCE_URL=https://login.salesforce.com

# App Configuration
PORT=3001
NODE_ENV=development

# JWT Authentication
# IMPORTANT: Change this to a secure random string for production
JWT_SECRET=permbridge-dev-secret-change-in-production

# Claude AI API (for permission analysis features)
ANTHROPIC_API_KEY=your-api-key-here
