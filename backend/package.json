{
  "name": "permbridge-backend",
  "version": "0.1.0",
  "description": "PermBridge backend API - Salesforce permission management",
  "main": "dist/app.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
